{
  "name": "mo2-webapi",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "release": "bumpp",
    "build": "bun run build:frontend",
